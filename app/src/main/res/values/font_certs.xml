<?xml version="1.0" encoding="utf-8"?>
<!--
    Сертификаты для Google Fonts провайдера (com.google.android.gms.fonts).
    Источник: официальная документация Android — Downloadable Fonts.
    Нужны для верификации провайдера при загрузке шрифтов.
-->
<resources>
    <array name="com_google_android_gms_fonts_certs">
        <item>@array/com_google_android_gms_fonts_certs_dev</item>
        <item>@array/com_google_android_gms_fonts_certs_prod</item>
    </array>

    <!-- Тестовый сертификат (dev-окружение) -->
    <string-array name="com_google_android_gms_fonts_certs_dev">
        <item>
            
        </item>
    </string-array>

    <!-- Производственный сертификат Google Play Services -->
    <string-array name="com_google_android_gms_fonts_certs_prod">
        <item>
            
        </item>
    </string-array>
</resources>
